# Copy this file to .env before running `docker compose up -d`.
# Pin a release tag in production so upgrades and rollbacks are deliberate.
OUTPACE_IMAGE=ghcr.io/jamezrin/outpace:0.1.0

# Host-side listener exposure. HTTP and RTMP default to loopback; peer traffic is public.
OUTPACE_HTTP_HOST=127.0.0.1
OUTPACE_HTTP_PORT=6878
OUTPACE_RTMP_HOST=127.0.0.1
OUTPACE_RTMP_PORT=1935

# Normal mode is a full P2P participant. Set both values to 0 for a pure leecher.
OUTPACE_ENABLE_INBOUND=1
OUTPACE_ENABLE_SEEDING=1

# Keep this off in normal bridge-mode Compose. See docs/deployment.md before enabling it.
OUTPACE_ENABLE_PORT_MAPPING=0

# `memory` is the safe default. For ephemeral disk-backed pieces, set `disk`.
OUTPACE_CACHE_TYPE=memory
OUTPACE_CACHE_DIR=/var/lib/outpace/cache
OUTPACE_SEED_STORE_BYTES=134217728

# Legacy /ace/* and /server/api routes remain experimental and opt-in.
OUTPACE_EXPERIMENTAL_ACE_COMPAT=0
